# Google Maps API Keys
# Copy this file to local.properties and add your actual API keys
# local.properties should NEVER be committed to git

# Android Google Maps API Key
GOOGLE_MAPS_API_KEY=YOUR_ANDROID_GOOGLE_MAPS_API_KEY_HERE

# iOS Google Maps API Key (if needed)
GOOGLE_MAPS_IOS_API_KEY=YOUR_IOS_GOOGLE_MAPS_API_KEY_HERE
